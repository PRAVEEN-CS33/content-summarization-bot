# ── REQUIRED ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_personal_chat_id    # find with @userinfobot

# ── OPTIONAL: YouTube Data API (scraping works without this) ──────────────────
YOUTUBE_API_KEY=

# ── OPTIONAL: Podcast Index API (free at podcastindex.org) ───────────────────
PODCAST_INDEX_API_KEY=
PODCAST_INDEX_API_SECRET=

# ── Google Gemini API ─────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key...      # get from aistudio.google.com/app/apikey
GEMINI_MODEL=gemini-2.0-flash              # fast + capable

# ── Whisper ───────────────────────────────────────────────────────────────────
WHISPER_MODEL=base                         # tiny | base | small | medium
WHISPER_DEVICE=cpu                         # cpu | cuda

# ── Scheduler ─────────────────────────────────────────────────────────────────
FETCH_INTERVAL_MINUTES=60                  # how often to check feeds
SUMMARY_HOUR=8                             # daily digest push at 8am IST
MAX_ITEMS_PER_RUN=10                       # max items processed per cycle

# ── Content limits ────────────────────────────────────────────────────────────
MAX_TRANSCRIPT_CHARS=12000
MAX_SUMMARY_TOKENS=600
